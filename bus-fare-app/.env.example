# Environment Variables

# Backend API Base URL
# Default: /api (uses Vite proxy in development)
# Production: Set to your actual backend URL
VITE_API_BASE_URL=/api

# RDMS Service URL (Fingerprint Scanner)
# Default: http://localhost:8005
VITE_RDMS_SERVICE_URL=http://localhost:8005

# Backend Server URL (for proxy)
# Used in vite.config.ts
VITE_BACKEND_URL=http://localhost:5000
